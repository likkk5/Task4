<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - UserManagement</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/UserManagement.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        .table-checkbox {
            width: 40px;
            text-align: center;
        }

        [data-bs-toggle="tooltip"] {
            cursor: help;
        }

        .status-unverified {
            background-color: #fff3cd;
            color: #856404;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-dark bg-dark mb-4">
        <div class="container-fluid">
            <span class="navbar-brand">
                <i class="fas fa-users me-2"></i>User Management System
            </span>
            <div class="d-flex">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <span class="navbar-text me-3">
                        <i class="fas fa-user me-1"></i>Welcome, @User.Identity.Name
                    </span>
                    <form asp-action="Logout" asp-controller="Account" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-light btn-sm">
                            <i class="fas fa-sign-out-alt me-1"></i>Logout
                        </button>
                    </form>
                }
                else
                {
                    <a asp-action="Login" asp-controller="Account" class="btn btn-outline-light btn-sm me-2">
                        <i class="fas fa-sign-in-alt me-1"></i>Sign In
                    </a>
                    <a asp-action="Register" asp-controller="Account" class="btn btn-outline-light btn-sm">
                        <i class="fas fa-user-plus me-1"></i>Register
                    </a>
                }
            </div>
        </div>
    </nav>

    <div class="container-fluid">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-4">
        <div class="container">
            &copy; 2026 - UserManagement
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>